{
  "chat.tools.terminal.autoApprove": {
    "/^node -e \"const p = require\\('\\./node_modules/@expo/vector-icons/package\\.json'\\); console\\.log\\('version:', p\\.version\\); const fs = require\\('fs'\\); console\\.log\\('Feather exists:', fs\\.existsSync\\('\\./node_modules/@expo/vector-icons/Feather\\.js'\\)\\); console\\.log\\('has useSafeAreaInsets:', fs\\.existsSync\\('\\./node_modules/react-native-safe-area-context/src/index\\.tsx'\\)\\);\"$/": {
      "approve": true,
      "matchCommandLine": true
